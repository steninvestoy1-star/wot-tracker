"build": {
  "appId": "com.wottracker.desktop",
  "productName": "WoT Tracker",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "electron/**/*",
    "build/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "standalone",
      "filter": ["**/*"]
    },
    {
      "from": ".next/static",
      "to": "standalone/.next/static",
      "filter": ["**/*"]
    },
    {
      "from": "public",
      "to": "standalone/public",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      "nsis",
      "portable"
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "shortcutName": "WoT Tracker",
    "uninstallDisplayName": "WoT Tracker",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico"
  }
}
